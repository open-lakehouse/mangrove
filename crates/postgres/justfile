_default:
    @just --list

# run the sharing sqlx migrations against a local Postgres
run-migrations:
    DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres \
        sqlx migrate run --source {{ source_directory() }}/migrations

# start a throwaway Postgres container for sharing migrations
docker:
  docker run \
    --name postgres-sharing \
    -e POSTGRES_PASSWORD=postgres \
    -e POSTGRES_USER=postgres \
    -e POSTGRES_DATABASE=postgres \
    -e POSTGRES_HOST_AUTH_METHOD=trust \
    -d \
    -p 5432:5432 \
    postgres

# regenerate the offline sqlx query cache for the workspace
prepare:
    cargo sqlx prepare --workspace
