{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "extends": "//",
  "files": {
    "includes": [
      "**",
      "!**/dist/**/*",
      "!**/node_modules/**/*",
      "!**/unity-catalog-client/src/uc-api.d.ts",
      "!**/unity-catalog/src/forms/schemas/**/*",
      "!**/query/src/gen/**/*"
    ]
  },
  "linter": {
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "noDefaultExport": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.stories.tsx", "**/vite.config.ts", "**/.storybook/**"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["data-grid/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "data-grid is a leaf: it must not import Unity Catalog. The Unity Catalog package may build on data-grid, never the reverse."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["query/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "query is a leaf: it must not import Unity Catalog. The Unity Catalog package may build on query, never the reverse."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["query-wasm/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "query-wasm implements the @open-lakehouse/query runner contract and must not import Unity Catalog UI: the app composes them, never the packages themselves."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["files-wasm/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "files-wasm implements the @open-lakehouse/files runner contract and must not import Unity Catalog UI: the app composes them, never the packages themselves."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["log-query/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "log-query is a leaf: it must not import Unity Catalog. The Unity Catalog package may build on log-query (renders a Delta-log tab), never the reverse."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["files/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "files is a leaf: it must not import Unity Catalog. The Unity Catalog package may build on files (renders a volume Files tab), never the reverse."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
