# Pin the public npm registry for this repo.
#
# Combined with npm's default `replace-registry-host=npmjs`, this makes `npm ci`
# fetch every package from registry.npmjs.org regardless of the host baked into
# each package-lock.json `resolved` URL. Without it, a lockfile regenerated on a
# machine configured for the internal mirror (npm-proxy.cloud.databricks.com)
# pins unreachable `resolved` hosts and CI fails with ETIMEDOUT.
#
# `integrity` hashes are host-independent, so overriding the host is safe.
registry=https://registry.npmjs.org/
