{
  "name": "unitycatalog",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "node/client",
    "node/ui-kit",
    "node/data-grid",
    "node/query",
    "node/query-wasm",
    "node/unity-catalog-client",
    "node/unity-catalog",
    "node/app",
    "docs",
    "examples/typescript"
  ],
  "scripts": {
    "openapi": "prettier --write openapi/openapi.yaml",
    "lint-fix": "biome check --write && biome format --write .",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov"
  },
  "dependencies": {
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0"
  }
}
