{
  "name": "unitycatalog",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "node/client",
    "node/ui-kit",
    "node/data-grid",
    "node/query",
    "node/query-wasm",
    "node/log-query",
    "node/files",
    "node/files-wasm",
    "node/editor",
    "node/unity-catalog-client",
    "node/unity-catalog",
    "node/app",
    "docs",
    "examples/typescript"
  ],
  "scripts": {
    "openapi": "prettier --write openapi/openapi.yaml",
    "lint-fix": "biome check --write && biome format --write .",
    "setup-hooks": "git config core.hooksPath .githooks",
    "strip-lock-proxy": "bun run scripts/strip-bun-lock-proxy.ts",
    "strip-lock-proxy:check": "bun run scripts/strip-bun-lock-proxy.ts --check",
    "cargo-lock-trestle:check": "bash scripts/check-cargo-lock-trestle.sh",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov"
  },
  "dependencies": {
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0"
  }
}
